# AI Employee Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!

# Vault Configuration
VAULT_PATH=/path/to/your/AI_Employee_Vault

# Watcher Configuration
WATCHER_CHECK_INTERVAL=30
ORCHESTRATOR_CHECK_INTERVAL=60

# Email Configuration (for future tiers)
# GMAIL_CLIENT_ID=your_client_id
# GMAIL_CLIENT_SECRET=your_client_secret
# GMAIL_REFRESH_TOKEN=your_refresh_token

# WhatsApp Configuration (for future tiers)
# WHATSAPP_SESSION_PATH=/secure/path/to/session

# Bank API Configuration (for future tiers)
# BANK_API_TOKEN=your_token

# Security Settings
DRY_RUN=true
MAX_ACTIONS_PER_HOUR=10
APPROVAL_THRESHOLD_USD=50

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=90
